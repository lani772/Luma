[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LUMA Smart Home"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Cloud Backend"

[[workflows.workflow]]
name = "LUMA Smart Home"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20792 pnpm --filter @workspace/luma-smart-home run dev"
waitForPort = 20792

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Cloud Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/luma-cloud-backend && GOSUMDB=sum.golang.org GONOSUMDB=golang.org/toolchain CLOUD_API_PORT=8090 go run ./cmd/api"
waitForPort = 8090

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
