# Copy to .env for local Docker Compose use. On Replit, these are supplied
# via the environment/secrets panel instead — see README.md.

ENV=development
CLOUD_API_PORT=8090

# Postgres connection string. On Replit this is provided automatically.
DATABASE_URL=postgres://luma:luma@localhost:5432/luma_cloud?sslmode=disable

# MongoDB connection string
MONGODB_URL=mongodb+srv://autodev100_db_user:lani12725@autodeve100.jlei1vy.mongodb.net/?appName=autodeve100

# Optional. When unset, the backend falls back to an in-memory cache (logged
# loudly at startup) — fine for a single dev instance, not for production or
# multi-instance deployments.
REDIS_URL=redis://localhost:6379/0

# Required. Used to derive both the access-token and refresh-token JWT
# signing keys. On Replit this reuses the existing SESSION_SECRET secret.
SESSION_SECRET=change-me-to-a-long-random-string

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=luma-cloud-backend

MQTT_BROKER_URL=tcp://mqtt.luma.local:1883
MQTT_CLIENT_ID_PREFIX=luma-cloud
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false

CORS_ORIGINS=*

RATE_LIMIT_RPM=120
RATE_LIMIT_BURST=40
