{
  "expo": {
    "name": "LUMA Smart Home",
    "slug": "luma-smart-home",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "luma-smart-home",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luma.smarthome"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.luma.smarthome"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "name": "LUMA Smart Home",
      "shortName": "LUMA",
      "description": "Premium smart home control — manage lights, energy, users & automations.",
      "themeColor": "#2563EB",
      "backgroundColor": "#0A0E1A",
      "lang": "en",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
